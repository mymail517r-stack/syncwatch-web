{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "nodeVersion": "18.x",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "Backend API URL for production",
      "example": "https://api.syncwatch.app"
    },
    "NEXT_PUBLIC_SOCKET_URL": {
      "description": "WebSocket server URL for production",
      "example": "https://api.syncwatch.app"
    }
  },
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 404
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
